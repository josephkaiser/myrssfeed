# Example environment configuration for myRSSfeed
#
# Copy this file to `.env` on your Raspberry Pi and replace the
# placeholder values with your own. The real `.env` file is ignored
# by git (see .gitignore) so secrets stay on-device.
#
#   cp .env.example .env
#   nano .env   # or your editor of choice
#

# General settings overrides (optional)
# MYRSSFEED_RETENTION_DAYS=90
# MYRSSFEED_MAX_ENTRIES=1000

# Wall Street Journal (WSJ) credentials for HTML reader / scraper login.
# These are NOT used anywhere yet in the app logic, but are defined here
# so you can safely store them on the Pi without committing them.
WSJ_USERNAME="your-wsj-username-here"
WSJ_PASSWORD="your-wsj-password-here"

