{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "strict": true,
    "noEmitOnError": true,
    "rootDir": "web/ts",
    "outDir": "web/static",
    "skipLibCheck": true
  },
  "include": ["web/ts/**/*.ts", "web/ts/**/*.d.ts"]
}
